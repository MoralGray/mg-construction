{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "name": "mg-construction-journal",
    "project": {
        "type": "application"
    },
    "sourceRoot": "apps/mg-construction-journal/src",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run build",
                "cwd": "apps/mg-construction-journal"
            }
        },
        "dev": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run dev",
                "cwd": "apps/mg-construction-journal"
            },
            "forwardAllArgs": true,
            "continuous": true
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run lint",
                "cwd": "apps/mg-construction-journal"
            }
        },
        "test": {
            "executor": "@nx/vite:test",
            "options": {
                "buildTarget": "mg-construction-journal:build"
            }
        },
        "typecheck": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run typecheck",
                "cwd": "apps/mg-construction-journal"
            }
        }
    }
}
